{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-explicit-any": "off",
    "no-non-null-assertion": "off",
    "no-await-in-loop": "off"
  },
  "env": {
    "builtin": true,
    "node": true
  },
  "ignorePatterns": ["dist", "node_modules", "plugin/**/*.py", "plugin/**/*.pyp"]
}
